# Copy this file to .env and fill in your key(s).
#   cp .env.example .env

# Anthropic — for the optional API engine (python backend/pipeline.py, no args).
# Get a key at https://platform.claude.com  (API Keys → create key)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini — for the autonomous engine (python backend/pipeline.py --gemini) and the
# scheduled GitHub Action. Get a key at https://aistudio.google.com/apikey
# (enable billing). In CI this is the GEMINI_API_KEY repo secret, not this file.
GEMINI_API_KEY=
